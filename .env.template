# Discord Bot Tokens — one per persona
# Create each bot at https://discord.com/developers/applications
DISCORD_TOKEN_AURION=your_aurion_bot_token_here
DISCORD_TOKEN_LIBRARIAN=your_librarian_bot_token_here
DISCORD_TOKEN_OBSERVER=your_observer_bot_token_here
DISCORD_TOKEN_LLAMA=your_llama_bot_token_here
DISCORD_TOKEN_MISTRAL=your_mistral_bot_token_here
DISCORD_TOKEN_DEEPSEEK=your_deepseek_bot_token_here

# The Discord channel where all bots will talk
CONVERSATION_CHANNEL_ID=your_channel_id_here

# Optional: dedicated channel for chess games (falls back to CONVERSATION_CHANNEL_ID)
CHESS_CHANNEL_ID=your_chess_channel_id_here

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434

# How often autonomous conversations trigger (seconds)
MIN_INTERVENTION_SECONDS=1800
MAX_INTERVENTION_SECONDS=10800

# Probability a conversation fires when the interval hits (0.0-1.0)
CONVERSATION_PROBABILITY=0.7

# Number of bot turns per conversation
MAX_CONVERSATION_TURNS=10

# Save conversations to JSON files in conversations/
ENABLE_CONVERSATION_LOGGING=true
